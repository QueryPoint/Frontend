# Backend URL the Vite dev-server proxy forwards /api requests to
VITE_API_PROXY_TARGET=http://localhost:8000

# Optional: override the axios baseURL directly (defaults to /api, proxied above)
# VITE_API_BASE_URL=/api

# Optional: override the assistant websocket URL
# (defaults to ws(s)://<current host>/api/ws)
# VITE_WS_URL=ws://localhost:8000/api/ws

# Max upload size in megabytes, must match the backend's limit
VITE_MAX_UPLOAD_SIZE_MB=20
